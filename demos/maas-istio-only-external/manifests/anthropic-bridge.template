# Anthropic bridge: HTTPRoute + AuthPolicy on the MaaS gateway
#
# Generate with:
#   sed "s|{{ANTHROPIC_API_KEY}}|$ANTHROPIC_API_KEY|g" anthropic-bridge.template > anthropic-bridge.yaml
#
# Anthropic differences from OpenAI:
#   - Auth header: x-api-key (not Authorization: Bearer)
#   - Extra header: anthropic-version (required)
#   - Endpoint: /v1/messages (not /v1/chat/completions)
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: anthropic-bridge
  namespace: openshift-ingress
spec:
  parentRefs:
    - name: maas-default-gateway
      namespace: openshift-ingress
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /external/anthropic/
      backendRefs:
        - name: anthropic-external
          port: 443
      filters:
        - type: URLRewrite
          urlRewrite:
            path:
              type: ReplacePrefixMatch
              replacePrefixMatch: /
        - type: RequestHeaderModifier
          requestHeaderModifier:
            set:
              - name: Host
                value: "api.anthropic.com"
              - name: anthropic-version
                value: "2023-06-01"
      timeouts:
        request: 300s
---
apiVersion: kuadrant.io/v1
kind: AuthPolicy
metadata:
  name: anthropic-bridge-auth
  namespace: openshift-ingress
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: anthropic-bridge
  rules:
    authentication:
      service-accounts:
        kubernetesTokenReview:
          audiences:
            - maas-default-gateway-sa
        defaults:
          userid:
            expression: |
              auth.identity.user.username.split(":")[3]
        cache:
          key:
            selector: context.request.http.headers.authorization.@case:lower
          ttl: 600
    response:
      success:
        headers:
          x-api-key:
            plain:
              expression: "'{{ANTHROPIC_API_KEY}}'"
---
apiVersion: kuadrant.io/v1alpha1
kind: TokenRateLimitPolicy
metadata:
  name: anthropic-bridge-trlp
  namespace: openshift-ingress
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: anthropic-bridge
  limits:
    external-anthropic:
      counters:
        - expression: auth.identity.userid
      rates:
        - limit: 100
          window: 1m
