# Anthropic bridge: HTTPRoute + AuthPolicy on the MaaS gateway
#
# Generate with:
#   sed "s|{{ANTHROPIC_API_KEY}}|$ANTHROPIC_API_KEY|g" anthropic-bridge.template > anthropic-bridge.yaml
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: anthropic-bridge
  namespace: openshift-ingress
spec:
  parentRefs:
    - name: maas-default-gateway
      namespace: openshift-ingress
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /external/anthropic/
      backendRefs:
        - name: anthropic-external
          port: 443
      filters:
        - type: URLRewrite
          urlRewrite:
            path:
              type: ReplacePrefixMatch
              replacePrefixMatch: /
        - type: RequestHeaderModifier
          requestHeaderModifier:
            set:
              - name: Host
                value: "api.anthropic.com"
              - name: anthropic-version
                value: "2023-06-01"
      timeouts:
        request: 300s
---
apiVersion: kuadrant.io/v1
kind: AuthPolicy
metadata:
  name: anthropic-bridge-auth
  namespace: openshift-ingress
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: anthropic-bridge
  rules:
    authentication:
      api-keys:
        plain:
          selector: request.headers.authorization
        priority: 0
      service-accounts:
        kubernetesTokenReview:
          audiences:
            - maas-default-gateway-sa
        defaults:
          userid:
            expression: |
              auth.identity.user.username.split(":")[3]
        priority: 1
    metadata:
      apiKeyValidation:
        http:
          body:
            expression: '{"key": request.headers.authorization.replace("Bearer ", "")}'
          contentType: application/json
          method: POST
          url: https://maas-api.opendatahub.svc.cluster.local:8443/internal/v1/api-keys/validate
        priority: 0
    authorization:
      api-key-valid:
        patternMatching:
          patterns:
            - operator: eq
              selector: auth.metadata.apiKeyValidation.valid
              value: "true"
        priority: 0
        when:
          - predicate: request.headers.authorization.startsWith("Bearer sk-oai-")
      sa-token-allowed:
        patternMatching:
          patterns:
            - operator: neq
              selector: auth.identity.user.username
              value: ""
        priority: 0
        when:
          - predicate: '!request.headers.authorization.startsWith("Bearer sk-oai-")'
    response:
      success:
        headers:
          x-api-key:
            plain:
              expression: "'{{ANTHROPIC_API_KEY}}'"
---
apiVersion: kuadrant.io/v1alpha1
kind: TokenRateLimitPolicy
metadata:
  name: anthropic-bridge-trlp
  namespace: openshift-ingress
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: anthropic-bridge
  limits:
    external-anthropic:
      counters:
        - expression: auth.identity.userid
      rates:
        - limit: 100
          window: 1m
