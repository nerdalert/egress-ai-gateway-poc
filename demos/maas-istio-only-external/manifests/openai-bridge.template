# OpenAI bridge: HTTPRoute + AuthPolicy on the MaaS gateway
#
# Generate with:
#   sed "s|{{OPENAI_API_KEY}}|$OPENAI_API_KEY|g" openai-bridge.template > openai-bridge.yaml
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: openai-bridge
  namespace: openshift-ingress
spec:
  parentRefs:
    - name: maas-default-gateway
      namespace: openshift-ingress
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /external/openai/
      backendRefs:
        - name: openai-external
          port: 443
      filters:
        - type: URLRewrite
          urlRewrite:
            path:
              type: ReplacePrefixMatch
              replacePrefixMatch: /
        - type: RequestHeaderModifier
          requestHeaderModifier:
            set:
              - name: Host
                value: "api.openai.com"
      timeouts:
        request: 300s
---
apiVersion: kuadrant.io/v1
kind: AuthPolicy
metadata:
  name: openai-bridge-auth
  namespace: openshift-ingress
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: openai-bridge
  rules:
    authentication:
      service-accounts:
        kubernetesTokenReview:
          audiences:
            - maas-default-gateway-sa
        defaults:
          userid:
            expression: |
              auth.identity.user.username.split(":")[3]
        cache:
          key:
            selector: context.request.http.headers.authorization.@case:lower
          ttl: 600
    response:
      success:
        headers:
          authorization:
            plain:
              expression: "'Bearer {{OPENAI_API_KEY}}'"
---
# TokenRateLimitPolicy overrides the gateway-level deny for this route
apiVersion: kuadrant.io/v1alpha1
kind: TokenRateLimitPolicy
metadata:
  name: openai-bridge-trlp
  namespace: openshift-ingress
spec:
  targetRef:
    group: gateway.networking.k8s.io
    kind: HTTPRoute
    name: openai-bridge
  limits:
    external-openai:
      counters:
        - expression: auth.identity.userid
      rates:
        - limit: 100
          window: 1m
